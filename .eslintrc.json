{
  "$schema": "https://json.schemastore.org/eslintrc",
  "root": true,
  "extends": ["next", "next/core-web-vitals"],
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "eqeqeq": ["error", "smart"],
    "consistent-return": "warn"
  }
}
